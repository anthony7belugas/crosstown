{
  "expo": {
    "name": "CrossTown",
    "slug": "crosstown",
    "version": "0.9.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "crosstown",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "owner": "anthony7belugas",
    "runtimeVersion": "0.9.0",
    "updates": {
      "url": "https://u.expo.dev/82a1d147-0894-47b1-b79d-31a4b5d5b13a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bestiesinc.crosstown",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.bestiesinc.crosstown"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "cameraPermission": false,
          "photosPermission": "CrossTown needs access to your photo library so you can pick photos for your player profile."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "backgroundColor": "#ffffff",
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "82a1d147-0894-47b1-b79d-31a4b5d5b13a"
      }
    }
  }
}
